{
    "buildCommand": "npm run build",
    "outputDirectory": "dist",
    "rewrites": [
        {
            "source": "/manifest.json",
            "destination": "/manifest.json"
        },
        {
            "source": "/icons/(.*)",
            "destination": "/icons/$1"
        },
        {
            "source": "/(.*)",
            "destination": "/index.html"
        }
    ]
}